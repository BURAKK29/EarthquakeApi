@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    var path = HttpContextAccessor.HttpContext.Request.Path.Value.ToLower();
    bool isAuthPages = path.Contains("/account/login") || path.Contains("/account/register");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EarthquakeApiProject</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"
          integrity="sha256-sA+e2U8mRz+2GVMOYXgjC+U2/h4JGSyYbXK4fC0pItY="
          crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"
            integrity="sha256-DvNbU4BCCDqv6brU6uyjHf1QXUL3Z7hM6UYGZwYy0vM="
            crossorigin=""></script>
</head>
<body>
    @if (!isAuthPages && User.Identity.IsAuthenticated)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark navbar-custom">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-controller="EarthquakeList" asp-action="Index">EarthquakeApiProject</a>                    <div class="navbar-collapse collapse">
                        <ul class="navbar-nav me-auto">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="FamilyMembers" asp-action="Index">Family Members</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="MyProfile">My Profile</a>
                            </li>
                        </ul>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>