{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=sql-server,1433;Database=EarthquakeDb;User Id=sa;Password=YOUR_DB_PASSWORD;Encrypt=False;TrustServerCertificate=True"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "Topic": "earthquake-topic",
    "GroupId": "earthquake-consumer-group",
    "BufferSize": 100,
    "WorkersCount": 1
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "Earthquake Alert",
    "SenderEmail": "your-email@gmail.com",
    "Username": "your-email@gmail.com",
    "Password": "YOUR_GMAIL_APP_PASSWORD"
  }
}
