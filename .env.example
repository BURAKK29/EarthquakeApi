# .env.example — Bu dosyayı kopyalayıp .env olarak kaydet, ardından gerçek değerleri gir.
# .env dosyası .gitignore'da tanımlıdır, GitHub'a gitmez.

# SQL Server SA şifresi
SA_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# Gmail App Password (Gmail > Güvenlik > Uygulama Şifresi)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
